      <inertia ixx="2.13676021558073e-06" ixy="-1.60287968590663e-11" ixz="6.52325549084054e-12" iyy="3.43246034957808e-06" iyz="-2.07705448960204e-16" izz="3.15697183373396e-06" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="3.14159 0 0" />
      <geometry>
        <mesh filename="../meshes/RR_foot.STL" />
      </geometry>
      <material name="foot_material">
        <color rgba="1 0.341176470588235 0.56078431372549 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.022" />
      </geometry>
    </collision>
  </link>
  <joint name="RR_foot_joint" type="fixed">
    <origin xyz="0 0 -0.181256552442637" rpy="0 0 0" />
    <parent link="RR_calf" />
    <child link="RR_foot" />
    <dont_collapse />
  </joint>

  
  <link name="camera_link" />
  <joint name="camera_joint" type="fixed">
    <parent link="base_link" />
    <child link="camera_link" />
    <origin xyz="0.238 -0.012 0.068" rpy="0 0.5236 0" />
  </joint>

  <gazebo reference="FL_foot"><mu1>100.0</mu1><mu2>100.0</mu2><kp>60.0</kp><kd>800.0</kd><minDepth>0.002</minDepth><maxVel>1.0</maxVel></gazebo>
  <gazebo reference="FR_foot"><mu1>100.0</mu1><mu2>100.0</mu2><kp>60.0</kp><kd>800.0</kd><minDepth>0.002</minDepth><maxVel>1.0</maxVel></gazebo>
  <gazebo reference="RL_foot"><mu1>100.0</mu1><mu2>100.0</mu2><kp>60.0</kp><kd>800.0</kd><minDepth>0.002</minDepth><maxVel>1.0</maxVel></gazebo>
  <gazebo reference="RR_foot"><mu1>100.0</mu1><mu2>100.0</mu2><kp>60.0</kp><kd>800.0</kd><minDepth>0.002</minDepth><maxVel>1.0</maxVel></gazebo>

  <ros2_control name="gazebo_system" type="system">
    <hardware><plugin>gazebo_ros2_control/GazeboSystem</plugin></hardware>
    <joint name="FL_hip_joint"><command_interface name="position" /><state_interface name="position" /><state_interface name="velocity" /></joint>
    <joint name="FL_thigh_joint"><command_interface name="position" /><state_interface name="position" /><state_interface name="velocity" /></joint>
    <joint name="FL_calf_joint"><command_interface name="position" /><state_interface name="position" /><state_interface name="velocity" /></joint>
    <joint name="FR_hip_joint"><command_interface name="position" /><state_interface name="position" /><state_interface name="velocity" /></joint>
    <joint name="FR_thigh_joint"><command_interface name="position" /><state_interface name="position" /><state_interface name="velocity" /></joint>
    <joint name="FR_calf_joint"><command_interface name="position" /><state_interface name="position" /><state_interface name="velocity" /></joint>
    <joint name="RL_hip_joint"><command_interface name="position" /><state_interface name="position" /><state_interface name="velocity" /></joint>
    <joint name="RL_thigh_joint"><command_interface name="position" /><state_interface name="position" /><state_interface name="velocity" /></joint>
    <joint name="RL_calf_joint"><command_interface name="position" /><state_interface name="position" /><state_interface name="velocity" /></joint>
    <joint name="RR_hip_joint"><command_interface name="position" /><state_interface name="position" /><state_interface name="velocity" /></joint>
    <joint name="RR_thigh_joint"><command_interface name="position" /><state_interface name="position" /><state_interface name="velocity" /></joint>
    <joint name="RR_calf_joint"><command_interface name="position" /><state_interface name="position" /><state_interface name="velocity" /></joint>
  </ros2_control>
  <gazebo>
    <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
      <parameters>__CONTROLLER_YAML__</parameters>
    </plugin>
  </gazebo>

  <gazebo reference="base_link">
    <sensor type="imu" name="imu_sensor">
      <always_on>true</always_on>
      <update_rate>200</update_rate>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian" stddev="0.01" /></x>
          <y><noise type="gaussian" stddev="0.01" /></y>
          <z><noise type="gaussian" stddev="0.01" /></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian" stddev="0.1" /></x>
          <y><noise type="gaussian" stddev="0.1" /></y>
          <z><noise type="gaussian" stddev="0.1" /></z>
        </linear_acceleration>
      </imu>
      <plugin name="gazebo_ros_imu_sensor" filename="libgazebo_ros_imu_sensor.so">
        <ros>
          <namespace>odin1</namespace>
          <remapping>~/out:=imu</remapping>
        </ros>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="base_link">
    <sensor type="depth" name="camera_depth_sensor">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <pose>0.238 -0.012 0.068 0 0.5236 0</pose>
      <camera name="camera_depth_camera">
        <horizontal_fov>1.51844</horizontal_fov>
        <image>
          <width>848</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>10.0</far>
        </clip>
      </camera>
      <plugin name="camera_depth_plugin" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>camera</namespace>
          <argument>image_raw:=depth/image_rect_raw</argument>
          <argument>camera_info:=depth/camera_info</argument>
        </ros>
        <camera_name>camera_depth</camera_name>
        <frame_name>camera_depth_optical_frame</frame_name>
        <hack_baseline>0.07</hack_baseline>
      </plugin>
    </sensor>
  </gazebo>

  <link name="camera_depth_optical_frame" />
  <joint name="camera_depth_joint" type="fixed">
    <parent link="base_link" />
    <child link="camera_depth_optical_frame" />
    <origin xyz="0.15 0 0.12" rpy="-1.5707963 0 -1.5707963" />
  </joint>

</robot>