    <texture name="grid" type="2d" builtin="checker" rgb1="0.15 0.15 0.15" rgb2="0.2 0.2 0.2" width="512" height="512"/>
    <texture name="skybox" type="skybox" builtin="gradient" rgb1="0.05 0.05 0.1" rgb2="0.02 0.02 0.05" width="512" height="512"/>
    <material name="groundplane" texture="grid" texrepeat="30 30" texuniform="true" reflectance="0.1"/>
    <material name="wall_material" rgba="0.25 0.25 0.28 1"/>
    <material name="body_material" rgba="0.79 0.82 0.93 1"/>
    <material name="foot_material" rgba="1 0.34 0.56 1"/>
  </asset>

  <worldbody>
