    <geom name="ground" type="plane" size="20 20 0.1" pos="0 0 0" material="groundplane" friction="2.0 0.5 0.01"/>
    <geom type="box" size="0.02 3 0.3" pos="8 0 0.3" material="wall_material"/>
    <geom type="box" size="3 0.02 0.3" pos="0 -5 0.3" material="wall_material"/>

    <geom name="step1" type="box" size="0.3 0.5 0.015" pos="1.0 0 0.015" material="wall_material" friction="1.5"/>
    <geom name="step2" type="box" size="0.3 0.5 0.02" pos="2.2 0 0.02" material="wall_material" friction="1.5"/>
    <geom name="step3" type="box" size="0.3 0.5 0.025" pos="3.5 0 0.025" material="wall_material" friction="1.5"/>
    <geom name="ramp" type="box" size="0.5 0.4 0.015" pos="4.8 0 0.015" euler="0 -0.06 0" material="wall_material" friction="1.5"/>
    <geom name="bump1" type="box" size="0.08 0.08 0.01" pos="1.6 0.1 0.01" material="wall_material"/>
    <geom name="bump2" type="box" size="0.06 0.06 0.015" pos="2.8 -0.1 0.015" material="wall_material"/>
    <geom name="bump3" type="box" size="0.1 0.1 0.01" pos="5.5 0.05 0.01" material="wall_material"/>
    <geom name="platform" type="box" size="0.4 0.5 0.03" pos="6.5 0 0.03" material="wall_material" friction="1.5"/>

