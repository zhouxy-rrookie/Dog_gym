<mujoco model="dog_urdf">
  <compiler meshdir="/root/gpufree-data/workspace/legged_gym/resources/robots/dog_urdf/meshes" angle="radian" autolimits="true"/>
  <option timestep="0.005" gravity="0 0 -9.81"/>

  <default>
    <joint damping="0.001" armature="0.01" frictionloss="0.1"/>
  </default>

  <asset>
    <mesh file="FL_hip.STL" name="FL_hip"/>
    <mesh file="FL_thigh.STL" name="FL_thigh"/>
    <mesh file="FL_calf.STL" name="FL_calf"/>
    <mesh file="FL_foot.STL" name="FL_foot"/>
    <mesh file="FR_hip.STL" name="FR_hip"/>
    <mesh file="FR_thigh.STL" name="FR_thigh"/>
    <mesh file="FR_calf.STL" name="FR_calf"/>
    <mesh file="FR_foot.STL" name="FR_foot"/>
